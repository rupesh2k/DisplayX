{
  "version": "1.0",
  "package_version": "2026-03-21T10:00:00Z",
  "settings": {
    "cache_size_gb": 5,
    "poll_interval_sec": 300,
    "health_report_url": "https://monitor.example.com/health",
    "analytics_webhook": "https://analytics.example.com/impressions"
  },
  "assets": [
    {
      "id": "logo",
      "type": "image",

      "cached": true
    },
    {
      "id": "promo-video",
      "type": "video",
      "url": "https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4",
      "cached": true
    }
  ],
  "schedule": [
    {
      "time_range": ["00:00", "23:59"],
      "playlist": ["logo", "promo-video"],
      "durations_sec": [10, 30],
      "transition": {
        "type": "crossfade",
        "duration_ms": 300
      }
    }
  ],
  "fallback": {
